# Copy to `.env` and fill in real values, then run `astro dev start`.
# `.env` is gitignored; only this example template is committed.
#
# The healthcheck DAG needs none of these — they are consumed by later
# milestones (Snowflake from M1, OpenAQ from M2/M3, SMTP from M9). Astro loads
# this file into the Airflow containers, so AIRFLOW_* names configure Airflow
# directly.

# --- OpenAQ API v3 ---
# Free key from https://explore.openaq.org (account -> API keys).
# Exposed to DAGs as an Airflow Variable: Variable.get("openaq_api_key").
AIRFLOW_VAR_OPENAQ_API_KEY=your-openaq-api-key

# --- Snowflake connection (conn_id: snowflake_default) ---
# JSON form of an Airflow connection. Key-pair auth (ADR-0018): AIRFLOW_USER is a
# TYPE=SERVICE user, so there is no password — `private_key_file` points at the
# RSA key you generate during bootstrap (include/sql/bootstrap/README.md). Astro
# bind-mounts the project into the container, so include/.keys/ (gitignored) is
# visible at /usr/local/airflow/include/.keys/. For an encrypted key, add
# "private_key_file_pwd": "<passphrase>" to extra.
#
# `account` is the organisation identifier <orgname>-<account_name> (hyphen),
# both parts readable from the Snowsight URL:
#   https://app.snowflake.com/<orgname>/<account_name>/...
# A bare account locator ("ab12345") resolves only in AWS us-west-2; elsewhere
# the connector fails with "404 Not Found ... /session/v1/login-request".
# After editing this file run `astro dev restart` — it is read at container start.
AIRFLOW_CONN_SNOWFLAKE_DEFAULT='{"conn_type": "snowflake", "login": "AIRFLOW_USER", "schema": "BRONZE", "extra": {"account": "your_org-your_account", "warehouse": "OPENAQ_WH", "database": "OPENAQ", "role": "OPENAQ_PIPELINE", "authenticator": "snowflake_jwt", "private_key_file": "/usr/local/airflow/include/.keys/airflow_user_rsa.p8"}}'

# --- Email / SMTP alerting (used by the notifier from M9) ---
AIRFLOW__SMTP__SMTP_HOST=smtp.example.com
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_STARTTLS=True
AIRFLOW__SMTP__SMTP_SSL=False
AIRFLOW__SMTP__SMTP_USER=your-smtp-user
AIRFLOW__SMTP__SMTP_PASSWORD=change-me
AIRFLOW__SMTP__SMTP_MAIL_FROM=airflow-openaq@example.com
# Comma-separated recipients for failure/deadline alerts.
AIRFLOW_VAR_ALERT_EMAIL_TO=you@example.com
